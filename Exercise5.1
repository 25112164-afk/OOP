import time
#1
total_seconds = time.time()
days = total_seconds // 86400
print(f"Total days: {days} days")
#2
seconds_today = total_seconds % 86400
hours = seconds_today // 3600
print(f"Hours: {hours}")
#3
seconds_left = seconds_today % 3600
minutes = seconds_left // 60
print(f"Minutes: {minutes}")
#4
seconds_final = seconds_left % 60
print(f"Seconds: {seconds_final}")